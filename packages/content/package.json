{
  "name": "@visualdsa/content",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "node scripts/build.mjs && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check . --ignore-path .prettierignore",
    "format:fix": "prettier --write . --ignore-path .prettierignore",
    "clean": "rimraf dist node_modules",
    "clean:turbo": "rimraf .turbo dist node_modules"
  },
  "dependencies": {
    "@visualdsa/types": "workspace:*"
  },
  "devDependencies": {
    "@visualdsa/eslint": "workspace:*",
    "@visualdsa/typescript": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
