# Optional: copy to apps/web/.env. The web app runs without this file.
#
# Canonical site URL — used for metadataBase / OpenGraph resolution.
# In production, set this to your deployed domain (e.g. https://visualdsa.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base URL of the NestJS API (default http://localhost:4000).
NEXT_PUBLIC_API_URL=http://localhost:4000
