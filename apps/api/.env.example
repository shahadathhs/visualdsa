# API environment. Copy to apps/api/.env (matches `compose.yaml`).
NODE_ENV=development

# Server port (default 4000)
PORT=4000

# PostgreSQL connection (host port 5434 -> container 5432)
DATABASE_URL="postgresql://visualdsa:visualdsa@localhost:5434/visualdsa?schema=public"

# Set SKIP_DB=true to boot without Prisma (used by the OpenAPI spec generator)
# SKIP_DB=true
